# Copy this file to config/project.env before running the project.
# Example: cp config/project.env.example config/project.env

# AWS region where all resources will be created.
AWS_REGION=us-east-1

# Short lowercase project name used in AWS and Kubernetes names.
PROJECT_NAME=eks-keda-lab

# Environment label such as dev, test, or prod.
ENVIRONMENT=dev

# Kubernetes 1.35 is a supported compatibility baseline for the pinned
# tutorial components as of July 23, 2026.
KUBERNETES_VERSION=1.35

# The script automatically discovers your public IPv4 address and limits
# the public EKS API endpoint to that one address. To set it yourself,
# use CIDR form, for example: PUBLIC_ACCESS_CIDR=203.0.113.10/32
PUBLIC_ACCESS_CIDR=

# Four m6i.large nodes provide a practical tutorial starting point for
# Kafka, two NiFi pods, KEDA, and two small web services.
NODE_INSTANCE_TYPE=m6i.large
NODE_DESIRED_SIZE=4
NODE_MIN_SIZE=3
NODE_MAX_SIZE=6
NODE_DISK_SIZE_GB=50

# The SSM-only test machine is small because it runs command-line tests,
# not the main applications.
RUNNER_INSTANCE_TYPE=t3.small

# Set true to keep Kafka and NiFi EBS volumes when Terraform destroys the
# Kubernetes objects. Retained volumes can continue to cost money.
RETAIN_APPLICATION_VOLUMES=true
